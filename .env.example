# Sentry is optional; leave blank in dev.
VITE_SENTRY_DSN=

# Supabase publishable values. Both are safe to ship to clients —
# RLS + rate limits enforce security on the backend, and the
# service_role key stays in Supabase Edge Functions (never here).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Production URL of the Rada desktop app landing / download page.
# The marketing site's "Start Building" and "Sign in" CTAs point here.
VITE_APP_URL=https://app.example.com
